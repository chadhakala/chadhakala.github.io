generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  drafts        Draft[]
}

model Draft {
  id          String      @id @default(cuid())
  title       String?
  content    String
  status      String      @default("draft") // draft, published, archived
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories  Category[]  @relation("DraftCategories")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  drafts    Draft[]  @relation("DraftCategories")
}
